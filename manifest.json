{
  "manifest_version": 3,
  "name": "antiAI",
  "description": "Hide or blur social media posts that appear to contain AI-generated images or videos.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.instagram.com/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*",
    "https://www.facebook.com/*",
    "https://www.threads.net/*",
    "https://www.tiktok.com/*",
    "https://www.youtube.com/*",
    "https://www.google.com/*",
    "https://www.bing.com/*",
    "https://yandex.com/*",
    "https://yandex.ru/*",
    "https://search.brave.com/*",
    "https://duckduckgo.com/*"
  ],
  "action": {
    "default_title": "antiAI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page-hook.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*",
        "https://www.facebook.com/*",
        "https://www.threads.net/*",
        "https://www.tiktok.com/*",
        "https://www.youtube.com/*",
        "https://www.google.com/*",
        "https://www.bing.com/*",
        "https://yandex.com/*",
        "https://yandex.ru/*",
        "https://search.brave.com/*",
        "https://duckduckgo.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
